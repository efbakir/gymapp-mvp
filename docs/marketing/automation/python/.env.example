# Unit marketing automation — credentials template
# Copy to .env (which is gitignored) and fill in values.
# Never commit the populated .env file.

# === ElevenLabs ===
# Get from https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Voice ID of your cloned voice (from Voice Lab in ElevenLabs)
ELEVENLABS_VOICE_ID=

# Voice settings (defaults from elevenlabs-protocol.md)
ELEVENLABS_STABILITY=0.50
ELEVENLABS_CLARITY=0.75
ELEVENLABS_STYLE=0.0
ELEVENLABS_SPEAKER_BOOST=false

# === Buffer ===
# Get from https://publish.buffer.com → Settings → Apps & Extras → Developer
BUFFER_ACCESS_TOKEN=

# Profile IDs per channel (use `curl -H "Authorization: Bearer $BUFFER_ACCESS_TOKEN" https://api.bufferapp.com/1/profiles.json` to get yours)
BUFFER_TIKTOK_PROFILE_ID=
BUFFER_IG_PROFILE_ID=
BUFFER_X_PROFILE_ID=
BUFFER_YT_SHORTS_PROFILE_ID=

# === Output paths (optional, sensible defaults) ===
OUTPUT_DIR=../sample-output
RAW_FOOTAGE_DIR=../raw-footage

# === Calendar source ===
CALENDAR_PATH=../../12-week-calendar.md
VOICEOVER_LIBRARY_PATH=../../scripts/voiceover-library.md
