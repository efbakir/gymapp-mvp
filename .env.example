# Set once Unit is live on the App Store. Pre-launch this stays empty and
# the marketing site shows the waitlist email form instead of the App Store
# badge. lib/launchState.ts reads this — no other file should reference it.
NEXT_PUBLIC_APP_STORE_URL=

# Resend credentials for the waitlist form. Without these, lib/waitlist.ts
# runs in stub mode (server-side console.log, returns ok). Once you create a
# Resend audience, drop the keys here and the live count starts flowing into
# the trust band.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
